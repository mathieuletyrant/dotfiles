{
  "languages": {
    "TypeScript": {
      "inlay_hints": {
        "enabled": true
      }
    }
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": []
  },
  "session": {
    "trust_all_worktrees": true
  },
  "terminal": {
    "cursor_shape": "bar"
  },
  "base_keymap": "VSCode",
  "preview_tabs": {
    "enabled": false
  },
  "minimap": {
    "show": "never"
  },
  "buffer_font_fallbacks": [
    "Menlo",
    "Monaco",
    "Courier New",
    "monospace"
  ],
  "buffer_font_family": "MesloLGS Nerd Font Mono",
  "tab_size": 2,
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "agent_buffer_font_size": 10.0,
  "agent_ui_font_size": 14.0,
  "ui_font_size": 14.0,
  "buffer_font_size": 13.0,
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Frappé",
    "dark": "VSCode Icons for Zed (Dark NestJS)"
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true,
  },
  "project_panel": {
    "indent_size": 13,
    "dock": "right",
  },
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Gruvbox Dark Soft"
  },
}
